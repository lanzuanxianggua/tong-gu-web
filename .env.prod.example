# ===== 生产环境环境变量 =====
# 复制此文件为 .env.production 并填写实际值
# cp .env.prod.example .env.production

# Django 密钥（必须更换，至少32字符）
# 生成方法：python -c "import secrets; print(secrets.token_urlsafe(50))"
SECRET_KEY=your-secret-key-here

# 生产环境必须为 False
DEBUG=False

# 允许的域名
ALLOWED_HOSTS=api.tong-gu.cn,localhost,127.0.0.1

# HTTPS 重定向（使用 CDN/反向代理时设为 False）
SECURE_SSL_REDIRECT=False

# ===== 数据库配置 =====
DB_NAME=tonggu
DB_USER=tonggu
DB_PASSWORD=your-database-password
DB_HOST=127.0.0.1
DB_PORT=3306
