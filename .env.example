# Django 密钥（生产环境必须修改！）
# 生成方法：from django.core.management.utils import get_random_secret_key; print(get_random_secret_key())
SECRET_KEY=your-secret-key-here-change-in-production

# Django 调试模式（生产环境必须为 False）
DEBUG=False

# 允许的域名（生产环境必须配置）
ALLOWED_HOSTS=localhost,127.0.0.1,your-domain.com,www.your-domain.com

# 数据库配置
DB_NAME=tong-gu
DB_USER=root
DB_PASSWORD=your-database-password
DB_HOST=127.0.0.1
DB_PORT=3306

# 前端 API 地址（生产环境修改为服务器地址）
VITE_API_BASE_URL=http://localhost:8000

# 日志级别（INFO/WARNING/ERROR/DEBUG）
LOG_LEVEL=INFO
